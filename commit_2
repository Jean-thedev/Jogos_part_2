typedef struct {
    int x, y;
    char dir;
    int hp;
    int arma;
}player;
void limparAtaque(char ataque[10][10]) {
    for(int y=0; y<10; y++) {
        for(int x=0; x<10; x++) {
            ataque[y][x] = ' ';
        }
    }
}
void atacar(player *p, char mapa[10][10], char ataque[10][10]) {
    int x_alvo, y_alvo;
    if (p->arma == 0) {
        printf("Você precisa pegar uma arma com o NPC primeiro!\n");
        system("pause");
        return;
    }
    if (p->arma == 1) {
        int i;
        for (i = 1; i <= 2; i++) {
            for (int j = -1; j <= 1; j++) {
                if (p->dir == '^') {
                    x_alvo = p->x + j;
                    y_alvo = p->y - i;
                } else if (p->dir == 'v') {
                    x_alvo = p->x + j;
                    y_alvo = p->y + i;
                } else if (p->dir == '<') {
                    x_alvo = p->x - i;
                    y_alvo = p->y + j;
                } else if (p->dir == '>') {
                    x_alvo = p->x + i;
                    y_alvo = p->y + j;
                }
                if (x_alvo >= 0 && x_alvo < 10 && y_alvo >= 0 && y_alvo < 10) {
                    ataque[y_alvo][x_alvo] = 'z';
                    if (mapa[y_alvo][x_alvo] == 'k' || mapa[y_alvo][x_alvo] == 'X' ||
                        mapa[y_alvo][x_alvo] == 'Y' || mapa[y_alvo][x_alvo] == 'Z' || mapa[y_alvo][x_alvo] == 'N') {
                        mapa[y_alvo][x_alvo] = ' ';
                    }
                }
            }
        }
    }
    else if (p->arma == 2) {
        for (int i = 1; i <= 4; i++) {
            if (p->dir == '^') { x_alvo = p->x; y_alvo = p->y - i; }
            else if (p->dir == 'v') { x_alvo = p->x; y_alvo = p->y + i; }
            else if (p->dir == '<') { x_alvo = p->x - i; y_alvo = p->y; }
            else if (p->dir == '>') { x_alvo = p->x + i; y_alvo = p->y; }
            if (x_alvo >= 0 && x_alvo < 10 && y_alvo >= 0 && y_alvo < 10) {
                ataque[y_alvo][x_alvo] = 'z';
                if (mapa[y_alvo][x_alvo] == 'k' || mapa[y_alvo][x_alvo] == 'X' ||
                    mapa[y_alvo][x_alvo] == 'Y' || mapa[y_alvo][x_alvo] == 'Z' || mapa[y_alvo][x_alvo] == 'N') {
                    mapa[y_alvo][x_alvo] = ' ';
                }
            }
        }
    }
    else if (p->arma == 3) {
        for (int dy = -1; dy <= 1; dy++) {
            for (int dx = -1; dx <= 1; dx++) {
                if (dx == 0 && dy == 0) continue;
                x_alvo = p->x + dx;
                y_alvo = p->y + dy;
                if (x_alvo >= 0 && x_alvo < 10 && y_alvo >= 0 && y_alvo < 10) {
                    ataque[y_alvo][x_alvo] = 'z';
                    if (mapa[y_alvo][x_alvo] == 'k' || mapa[y_alvo][x_alvo] == 'X' ||
                        mapa[y_alvo][x_alvo] == 'Y' || mapa[y_alvo][x_alvo] == 'Z' || mapa[y_alvo][x_alvo] == 'N') {
                        mapa[y_alvo][x_alvo] = ' ';
                    }
                }
            }
        }
    }
}
