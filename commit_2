            break;
    }
    system("pause");
}
int tangivel(char mapa[10][10], int x, int y) {
    switch(mapa[y][x]) {
        case '*':
        case 'N':
        case 'D':
        case 'k':
            return 0;

        default:
            return 1;
    }
}
void mover(player *p, char tecla) {
    switch (tecla) {
        case 'w': p->y--; p->dir = '^'; break;
        case 's': p->y++; p->dir = 'v'; break;
        case 'a': p->x--; p->dir = '<'; break;
        case 'd': p->x++; p->dir = '>'; break;
    }
}
void desenharmapa(char mapa[10][10], char ataque[10][10], player jogador) {
    int x, y;
    for(y = 0; y < 10; y++) {
        for(x = 0; x < 10; x++) {
            if(x == jogador.x && y == jogador.y)
                printf("%c", jogador.dir);
            else if(ataque[y][x] == 'z')
                printf("z");
            else
                printf("%c", mapa[y][x]);
        }
        printf("\n");
    }
}
